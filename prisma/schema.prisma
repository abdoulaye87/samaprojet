datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  cash      Float    @default(5000)
  type      String   @default("player") // "player" or "agent"
  createdAt DateTime @default(now())

  businessesSent    Transaction[] @relation("FromUser")
  businessesReceived Transaction[] @relation("ToUser")
  ownedBusinesses   Business[]
}

model Business {
  id       String  @id @default(uuid())
  ownerId  String
  name     String
  revenue  Float
  cost     Float
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Transaction {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  amount     Float
  type       String   // "achat", "vente", "transfert"
  createdAt  DateTime @default(now())

  fromUser User @relation("FromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ToUser", fields: [toUserId], references: [id], onDelete: Cascade)
}
